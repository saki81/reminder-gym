


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

  
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String?
  
  activeGymId           String?
  activeGym             Gym?      @relation("ActiveGymId",fields: [activeGymId], references: [id])

  
  emailVerified   Boolean @default(false)
  emailVerifiedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  admins          Admin[]

  equipments      Equipment[]
  maintenances    Maintenance[]

  resetTokens       PasswordResetToken[]
  verifyTokens      EmailVerificationToken[]
  resetSessions     PasswordResetSession[]

  @@index([email])
  @@index([activeGymId])

}


enum AdminRole {
  ADMIN
  OWNER
  STAFF
}

model Admin {
  id        String    @id @default(uuid())

  userId    String    
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      AdminRole @default(STAFF)
  gymId     String?   // null za platform ADMIN
  gym       Gym?      @relation(fields: [gymId], references: [id])

  createdAt DateTime  @default(now())

  isOwner   Boolean   @default(false)

  @@unique([userId, gymId], name: "admin_user_gym_unique")
  @@index([gymId])
}
// Password reset token (forgot password)
model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([userId, expiresAt])
}
model PasswordResetSession {
  id        String   @id @default(uuid())
  token     String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([userId, expiresAt])
}
// Tokens for OTP, email verification
model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Equipment {
  id         String     @id @default(uuid())
  name       String

  brand      String?
  model      String?

  inventoryNumber  String?
  serialNumber  String?

  serviceIntervalDays   Int   @default(180)

  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)


  maintenances Maintenance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([gymId, inventoryNumber])
  @@index([gymId])
  @@index([userId])
  @@index([categoryId])
}

model Category {
  id        String    @id @default(uuid())
  name      String  
 

  createdAt DateTime  @default(now())

  gymId     String
  gym       Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  equipments Equipment[]

  @@unique([gymId, name])
  @@index([ gymId])
 
}

model Maintenance {
  id          String    @id @default(uuid())

  title       String
  description String?

  cost        Float?

  status      MaintenanceStatus @default(COMPLETED)

  performedAt DateTime
  nextDueDate DateTime?

  equipmentId String
  equipment  Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  gymId       String
  gym         Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)


  createdAt   DateTime @default(now())

   @@index([equipmentId])
   @@index([userId])
}

enum MaintenanceStatus {
  COMPLETED 
  SCHEDULED
}

model Gym {
  id           String      @id  @default(uuid())
  gymName      String
  city         String?

 
  equipments   Equipment[]
  maintenances Maintenance[]
  categories   Category[]

  admins       Admin[]

  activeUsers  User[] @relation("ActiveGymId")

  createdAt    DateTime    @default(now())
}





